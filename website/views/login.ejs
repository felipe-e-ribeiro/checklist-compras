<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Lista de Compras</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="login-page">
    <div class="login-card">
      <div class="login-mark">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
      </div>

      <h1 class="login-title">Lista de<br>Compras</h1>
      <p class="login-sub">Organize as compras da família em tempo real, com todos em sincronia.</p>

      <% if (typeof query !== 'undefined' && query && query.deleted === '1') { %>
        <div style="background:var(--accent-light);color:var(--accent);border-radius:var(--radius-sm);padding:10px 14px;font-size:14px;margin-bottom:16px;">
          Sua conta foi deletada e seus dados foram anonimizados.
        </div>
      <% } %>

      <!-- Banner de consentimento — exibido enquanto não há aceite em localStorage -->
      <div id="consent-banner" style="display:none;background:var(--surface-alt);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;margin-bottom:16px;font-size:13px;color:var(--text-muted)">
        <p style="margin-bottom:8px">
          Este serviço utiliza <strong style="color:var(--text)">cookies necessários</strong> para autenticação
          (tokens de sessão HttpOnly). Ao entrar, seus dados do Google (e-mail e nome)
          serão armazenados para fornecer o serviço.
        </p>
        <p style="margin-bottom:10px">
          Base legal: execução de contrato (RGPD Art. 6(1)(b)).
          <a href="/privacy" style="color:var(--accent)" target="_blank">Política de Privacidade</a>
        </p>
        <button id="accept-btn" class="btn btn-primary" style="height:36px;font-size:13px">
          Aceitar e Continuar
        </button>
      </div>

      <!-- Botão de login — visível apenas após consentimento -->
      <div id="login-btn-wrap" style="display:none">
        <a href="/auth/google" class="btn btn-google">
          <svg width="18" height="18" viewBox="0 0 18 18">
            <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 01-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/>
            <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z"/>
            <path fill="#FBBC05" d="M3.964 10.706A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.706V4.962H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.038l3.007-2.332z"/>
            <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.962L3.964 7.294C4.672 5.163 6.656 3.58 9 3.58z"/>
          </svg>
          Entrar com Google
        </a>

        <div class="login-divider"></div>
        <p style="font-size:12px;color:var(--text-muted);text-align:center">
          <a href="/privacy" style="color:var(--accent)">Política de Privacidade</a>
          &nbsp;·&nbsp;
          <a href="#" id="reset-consent" style="color:var(--text-muted)">Revogar consentimento</a>
        </p>
      </div>
    </div>
  </div>

  <script>
    const CONSENT_KEY = 'gdpr_consent_v1';

    function showLogin() {
      document.getElementById('consent-banner').style.display = 'none';
      document.getElementById('login-btn-wrap').style.display = 'block';
    }

    function showBanner() {
      document.getElementById('consent-banner').style.display = 'block';
      document.getElementById('login-btn-wrap').style.display = 'none';
    }

    // Verificar consentimento existente
    if (localStorage.getItem(CONSENT_KEY) === 'accepted') {
      showLogin();
    } else {
      showBanner();
    }

    document.getElementById('accept-btn').addEventListener('click', () => {
      localStorage.setItem(CONSENT_KEY, 'accepted');
      showLogin();
    });

    document.getElementById('reset-consent')?.addEventListener('click', (e) => {
      e.preventDefault();
      localStorage.removeItem(CONSENT_KEY);
      showBanner();
    });
  </script>
</body>
</html>
