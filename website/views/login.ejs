<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Lista de Compras</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    /* ── Checkbox de consentimento ── */
    .consent-row {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 20px;
      cursor: pointer;
      user-select: none;
    }
    .consent-checkbox {
      position: relative;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .consent-checkbox input {
      position: absolute;
      opacity: 0;
      width: 0;
      height: 0;
    }
    .consent-box {
      width: 20px;
      height: 20px;
      border: 1.5px solid var(--border);
      border-radius: 5px;
      background: var(--surface);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s ease;
    }
    .consent-checkbox input:checked + .consent-box {
      background: var(--accent);
      border-color: var(--accent);
    }
    .consent-checkmark {
      opacity: 0;
      transform: scale(0.5);
      transition: all 0.15s ease;
      color: #fff;
    }
    .consent-checkbox input:checked + .consent-box .consent-checkmark {
      opacity: 1;
      transform: scale(1);
    }
    .consent-text {
      font-size: 13px;
      color: var(--text-muted);
      line-height: 1.5;
    }
    .consent-text a { color: var(--accent); text-decoration: underline; }

    /* ── Botão Google desativado ── */
    .btn-google-wrap { transition: opacity 0.2s ease; }
    .btn-google-wrap.locked {
      opacity: 0.38;
      pointer-events: none;
      filter: grayscale(0.4);
    }
    .btn-google-wrap.locked .btn-google { cursor: not-allowed; }

    /* ── Reset link ── */
    .reset-link {
      font-size: 11px;
      color: var(--border);
      cursor: pointer;
      text-align: center;
      display: block;
      margin-top: 10px;
      transition: color 0.15s;
    }
    .reset-link:hover { color: var(--text-muted); }
  </style>
</head>
<body>
  <div class="login-page">
    <div class="login-card">
      <div class="login-mark">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
      </div>

      <h1 class="login-title">Lista de<br>Compras</h1>
      <p class="login-sub">Organize as compras da família em tempo real, com todos em sincronia.</p>

      <% if (typeof query !== 'undefined' && query && query.deleted === '1') { %>
        <div style="background:var(--accent-light);color:var(--accent);border-radius:var(--radius-sm);padding:10px 14px;font-size:13px;margin-bottom:20px;display:flex;align-items:center;gap:8px">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
          Conta deletada — dados anonimizados com sucesso.
        </div>
      <% } %>

      <!-- Checkbox de consentimento inline -->
      <label class="consent-row" id="consent-label">
        <span class="consent-checkbox">
          <input type="checkbox" id="consent-check">
          <span class="consent-box">
            <svg class="consent-checkmark" width="11" height="11" viewBox="0 0 12 10" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="1.5,5 4.5,8 10.5,1.5"/>
            </svg>
          </span>
        </span>
        <span class="consent-text">
          Li e aceito a
          <a href="/privacy" target="_blank" onclick="event.stopPropagation()">Política de Privacidade</a>
          — usamos apenas cookies necessários para autenticação.
        </span>
      </label>

      <!-- Botão Google — bloqueado até consentimento -->
      <div class="btn-google-wrap locked" id="google-wrap">
        <a href="/auth/google" class="btn btn-google">
          <svg width="18" height="18" viewBox="0 0 18 18">
            <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 01-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/>
            <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z"/>
            <path fill="#FBBC05" d="M3.964 10.706A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.706V4.962H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.038l3.007-2.332z"/>
            <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.962L3.964 7.294C4.672 5.163 6.656 3.58 9 3.58z"/>
          </svg>
          Entrar com Google
        </a>
      </div>

      <span class="reset-link" id="reset-consent" style="display:none">
        Revogar consentimento
      </span>
    </div>
  </div>

  <script>
    const CONSENT_KEY = 'gdpr_consent_v1';
    const check = document.getElementById('consent-check');
    const wrap  = document.getElementById('google-wrap');
    const reset = document.getElementById('reset-consent');

    function applyConsent(accepted) {
      check.checked = accepted;
      wrap.classList.toggle('locked', !accepted);
      reset.style.display = accepted ? 'block' : 'none';
    }

    // Restaurar estado salvo
    applyConsent(localStorage.getItem(CONSENT_KEY) === 'accepted');

    check.addEventListener('change', () => {
      const accepted = check.checked;
      accepted
        ? localStorage.setItem(CONSENT_KEY, 'accepted')
        : localStorage.removeItem(CONSENT_KEY);
      applyConsent(accepted);
    });

    reset.addEventListener('click', () => {
      localStorage.removeItem(CONSENT_KEY);
      applyConsent(false);
    });
  </script>
</body>
</html>
