<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Lista de Compras</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <script src="/socket.io/socket.io.js"></script>

  <%
    const currentWorkspace = allWorkspaces.find(w => w.id === tenantId) || { name: 'Lista' };
    const isOwner = userRole === 'owner';
    const canCreate = ownedCount < 3;
  %>

  <!-- ── Navbar ──────────────────────────────────────────────────────── -->
  <nav class="nav">
    <!-- Workspace dropdown -->
    <div class="ws-dropdown-wrap">
      <button class="ws-trigger" id="ws-trigger" aria-expanded="false" aria-haspopup="true">
        <div class="brand-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 01-8 0"/>
          </svg>
        </div>
        <span class="ws-name"><%= currentWorkspace.name %></span>
        <svg class="ws-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </button>

      <div class="ws-menu" id="ws-menu" role="menu">
        <!-- Workspaces do usuário -->
        <% allWorkspaces.forEach(function(ws) { %>
          <% if (ws.id === tenantId) { %>
            <div class="ws-item active" role="menuitem">
              <svg class="ws-item-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span><%= ws.name %></span>
              <span class="ws-item-role"><%= ws.role === 'owner' ? 'Dono' : 'Membro' %></span>
            </div>
          <% } else { %>
            <form method="POST" action="/workspace/switch" style="margin:0">
              <input type="hidden" name="tenantId" value="<%= ws.id %>">
              <button type="submit" class="ws-item" role="menuitem">
                <span style="width:14px;flex-shrink:0"></span>
                <span><%= ws.name %></span>
                <span class="ws-item-role"><%= ws.role === 'owner' ? 'Dono' : 'Membro' %></span>
              </button>
            </form>
          <% } %>
        <% }); %>

        <div class="ws-sep"></div>

        <!-- Gerenciar (só para owners) -->
        <% if (isOwner) { %>
          <button class="ws-action" id="manage-btn" role="menuitem">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/>
            </svg>
            Gerenciar workspace
          </button>
        <% } %>

        <!-- Criar novo -->
        <a href="/create-workspace" class="ws-action <%= canCreate ? '' : 'disabled' %>" role="menuitem">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          <% if (canCreate) { %>
            Criar novo (<%= ownedCount %>/3)
          <% } else { %>
            Limite atingido (3/3)
          <% } %>
        </a>
      </div>
    </div>

    <!-- Nav direita -->
    <div class="nav-right">
      <span class="nav-email"><%= user.email %></span>
      <button class="btn-icon" id="theme-toggle" title="Alternar tema">
        <svg id="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg id="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
      </button>
      <form method="POST" action="/auth/logout" style="display:inline">
        <button class="btn btn-ghost btn-sm" type="submit">Sair</button>
      </form>
    </div>
  </nav>

  <!-- ── Main ────────────────────────────────────────────────────────── -->
  <main class="app-container fade-in">
    <form id="add-form" class="add-bar" method="POST" action="/app/add">
      <input class="input-field" type="text" id="item-input" name="item" placeholder="Adicionar item à lista…" required autocomplete="off">
      <button class="btn btn-primary" type="submit">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Adicionar
      </button>
    </form>

    <div class="item-list-wrap">
      <div class="sort-bar">
        <div class="sort-tabs">
          <button class="sort-tab <%= sortBy === 'item' ? 'active' : '' %>" data-sort="item">Alfabética</button>
          <button class="sort-tab <%= sortBy === 'checked' ? 'active' : '' %>" data-sort="checked">Concluídos</button>
        </div>
        <div class="sort-actions">
          <form method="POST" action="/app/clear-checked">
            <button type="submit" class="btn btn-danger-ghost">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 11 12 14 22 4"/>
                <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
              </svg>
              Limpar concluídos
            </button>
          </form>
        </div>
      </div>

      <ul class="item-list" id="item-list">
        <% if (items.length === 0) { %>
          <li class="item-empty" id="empty-state">
            <div class="item-empty-icon">🛒</div>
            <div>Sua lista está vazia.<br>Adicione o primeiro item acima.</div>
          </li>
        <% } %>
        <% items.forEach(function(item) { %>
          <li class="item-row" data-id="<%= item.id %>">
            <label class="item-label">
              <input class="item-checkbox-input" type="checkbox" onchange="checkItem('<%= item.id %>', this.checked)" <%= item.checked ? 'checked' : '' %>>
              <span class="item-box">
                <svg viewBox="0 0 12 10" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="1.5,5 4.5,8 10.5,1.5"/>
                </svg>
              </span>
              <span class="item-text"><%= item.item %></span>
            </label>
          </li>
        <% }); %>
      </ul>
    </div>
  </main>

  <!-- ── Modal de gerenciamento ───────────────────────────────────────── -->
  <% if (isOwner) { %>
  <div class="modal-overlay" id="manage-modal" role="dialog" aria-modal="true">
    <div class="modal-box">
      <div class="modal-header">
        <span class="modal-title"><%= currentWorkspace.name %></span>
        <button class="modal-close" id="modal-close" aria-label="Fechar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <div class="modal-body">
        <!-- Membros -->
        <div class="modal-section-label">Membros (<%= members.length %>)</div>
        <div id="members-list">
          <% members.forEach(function(m) { %>
            <div class="member-row" data-member-id="<%= m.id %>">
              <div class="member-avatar"><%= (m.name || m.email || '?')[0].toUpperCase() %></div>
              <div class="member-info">
                <div class="member-name"><%= m.name || m.email %></div>
                <div class="member-email"><%= m.email %></div>
              </div>
              <% if (m.role === 'owner') { %>
                <span class="member-badge">Dono</span>
              <% } else { %>
                <span class="member-badge member-badge-member">Membro</span>
                <button class="btn btn-ghost revoke-btn revoke-btn-normal" data-user-id="<%= m.id %>">Revogar</button>
              <% } %>
            </div>
          <% }); %>
        </div>

        <!-- Convidar -->
        <div class="invite-section">
          <div class="modal-section-label" style="margin-top:16px">Convidar</div>
          <div id="invite-area">
            <button class="btn btn-ghost" id="gen-invite-btn" style="width:100%">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>
              </svg>
              Gerar link de convite
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- ── Toast container ──────────────────────────────────────────────── -->
  <div class="toast-container" id="toast-container"></div>

  <script>
    // ── Tema ─────────────────────────────────────────────────────────
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const theme = localStorage.getItem('theme') || (prefersDark ? 'dark' : 'light');
    document.documentElement.setAttribute('data-theme', theme);
    updateThemeIcon(theme);
    document.getElementById('theme-toggle').addEventListener('click', () => {
      const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      updateThemeIcon(next);
    });
    function updateThemeIcon(t) {
      document.getElementById('icon-sun').style.display  = t === 'dark'  ? 'block' : 'none';
      document.getElementById('icon-moon').style.display = t === 'light' ? 'block' : 'none';
    }

    // ── Sort ──────────────────────────────────────────────────────────
    document.querySelectorAll('.sort-tab').forEach((btn) => {
      btn.addEventListener('click', () => {
        window.location.href = `/app?sortBy=${btn.dataset.sort}`;
      });
    });

    // ── Socket.IO ─────────────────────────────────────────────────────
    const socket = io({ auth: { tenantId: '<%= tenantId %>' } });
    socket.on('item-added', (data) => {
      document.getElementById('empty-state')?.remove();
      const li = document.createElement('li');
      li.className = 'item-row';
      li.dataset.id = data.id;
      li.innerHTML = `
        <label class="item-label">
          <input class="item-checkbox-input" type="checkbox" onchange="checkItem('${data.id}', this.checked)">
          <span class="item-box">
            <svg viewBox="0 0 12 10" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="1.5,5 4.5,8 10.5,1.5"/>
            </svg>
          </span>
          <span class="item-text">${data.item}</span>
        </label>`;
      document.getElementById('item-list').appendChild(li);
    });
    socket.on('item-checked', (data) => {
      if (!data || !data.id) return;
      const el = document.querySelector(`li[data-id="${data.id}"] .item-checkbox-input`);
      if (el) el.checked = !!data.checked;
    });
    socket.on('items-cleared', () => {
      document.querySelectorAll('.item-row').forEach((row) => {
        if (row.querySelector('.item-checkbox-input')?.checked) row.remove();
      });
      // Mostrar estado vazio se não sobrou nenhum item
      if (!document.querySelector('.item-row') && !document.getElementById('empty-state')) {
        const empty = document.createElement('li');
        empty.id = 'empty-state';
        empty.className = 'item-empty';
        empty.innerHTML = '<div class="item-empty-icon">🛒</div><div>Sua lista está vazia.<br>Adicione o primeiro item acima.</div>';
        document.getElementById('item-list').appendChild(empty);
      }
    });
    function checkItem(id, checked) {
      fetch('/app/check', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({ id, checked: checked ? 'on' : 'off' }),
      });
    }

    // ── Workspace dropdown ────────────────────────────────────────────
    const wsTrigger = document.getElementById('ws-trigger');
    const wsMenu = document.getElementById('ws-menu');
    wsTrigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = wsMenu.classList.toggle('open');
      wsTrigger.setAttribute('aria-expanded', open);
    });
    document.addEventListener('click', () => {
      wsMenu.classList.remove('open');
      wsTrigger.setAttribute('aria-expanded', 'false');
    });
    wsMenu.addEventListener('click', (e) => e.stopPropagation());
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        wsMenu.classList.remove('open');
        wsTrigger.setAttribute('aria-expanded', 'false');
      }
    });

    // ── Modal de gerenciamento ────────────────────────────────────────
    <% if (isOwner) { %>
    const manageModal = document.getElementById('manage-modal');
    const manageBtn = document.getElementById('manage-btn');
    const modalClose = document.getElementById('modal-close');

    function openModal() {
      wsMenu.classList.remove('open');
      wsTrigger.setAttribute('aria-expanded', 'false');
      manageModal.classList.add('open');
    }
    function closeModal() { manageModal.classList.remove('open'); }

    manageBtn.addEventListener('click', openModal);
    modalClose.addEventListener('click', closeModal);
    manageModal.addEventListener('click', (e) => { if (e.target === manageModal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    // ── Revogar membro ────────────────────────────────────────────────
    document.querySelectorAll('.revoke-btn').forEach((btn) => {
      let timer = null;
      btn.addEventListener('click', () => {
        if (btn.classList.contains('revoke-btn-confirm')) {
          // Segundo clique — executar
          clearTimeout(timer);
          const userId = btn.dataset.userId;
          fetch(`/workspace/members/${userId}`, { method: 'DELETE' })
            .then((r) => {
              if (r.ok) {
                const row = btn.closest('.member-row');
                row.style.opacity = '0';
                row.style.transition = 'opacity .3s';
                setTimeout(() => row.remove(), 300);
              }
            });
        } else {
          // Primeiro clique — pedir confirmação
          btn.textContent = 'Confirmar?';
          btn.classList.remove('revoke-btn-normal');
          btn.classList.add('revoke-btn-confirm');
          timer = setTimeout(() => {
            btn.textContent = 'Revogar';
            btn.classList.remove('revoke-btn-confirm');
            btn.classList.add('revoke-btn-normal');
          }, 3000);
        }
      });
    });

    // ── Convite com countdown 60s ─────────────────────────────────────
    const genInviteBtn = document.getElementById('gen-invite-btn');
    const inviteArea = document.getElementById('invite-area');
    let countdownTimer = null;

    genInviteBtn.addEventListener('click', async () => {
      const res = await fetch('/workspace/invite', { method: 'POST' });
      if (!res.ok) return;
      const { inviteUrl } = await res.json();
      startInviteCountdown(inviteUrl);
    });

    function startInviteCountdown(url) {
      clearInterval(countdownTimer);
      let secs = 60;
      inviteArea.innerHTML = `
        <div class="invite-countdown-wrap">
          <div class="invite-url-row">
            <span class="invite-url-text" title="${url}">${url}</span>
            <button class="btn btn-ghost btn-sm invite-copy-btn" id="copy-invite-btn">Copiar</button>
          </div>
          <div class="invite-timer-row">
            <span class="invite-timer" id="invite-timer">Expira em ${secs}s</span>
          </div>
        </div>`;

      document.getElementById('copy-invite-btn').addEventListener('click', () => {
        navigator.clipboard.writeText(url).then(() => {
          const b = document.getElementById('copy-invite-btn');
          if (b) { b.textContent = '✓ Copiado'; setTimeout(() => { if (b) b.textContent = 'Copiar'; }, 2000); }
        });
      });

      countdownTimer = setInterval(() => {
        secs--;
        const timerEl = document.getElementById('invite-timer');
        if (!timerEl) { clearInterval(countdownTimer); return; }
        if (secs <= 0) {
          clearInterval(countdownTimer);
          inviteArea.innerHTML = `
            <div class="invite-countdown-wrap">
              <span class="invite-expired-msg">Link expirado.</span>
              <button class="btn btn-ghost btn-sm" id="gen-invite-btn" style="margin-top:8px;width:100%">Gerar novo link</button>
            </div>`;
          document.getElementById('gen-invite-btn').addEventListener('click', async () => {
            const r = await fetch('/workspace/invite', { method: 'POST' });
            if (r.ok) { const { inviteUrl } = await r.json(); startInviteCountdown(inviteUrl); }
          });
        } else {
          timerEl.textContent = `Expira em ${secs}s`;
          if (secs <= 10) timerEl.classList.add('expiring');
        }
      }, 1000);
    }
    <% } %>

    // ── Add form — fetch sem page reload; Socket.IO trata o DOM ─────────
    document.getElementById('add-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = document.getElementById('item-input');
      const item = input.value.trim();
      if (!item) return;

      const res = await fetch('/app/add', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'Accept': 'application/json',
        },
        body: new URLSearchParams({ item }),
      });

      if (res.ok) {
        input.value = '';
        input.focus();
      }
    });

    // ── Clear checked — fetch sem page reload; Socket.IO trata o DOM ────
    document.querySelector('form[action="/app/clear-checked"]')
      .addEventListener('submit', async (e) => {
        e.preventDefault();
        await fetch('/app/clear-checked', {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
        });
      });
  </script>
</body>
</html>
