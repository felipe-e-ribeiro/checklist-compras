<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Erro — Lista de Compras</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="page-center">
    <div class="page-card" style="text-align:center;max-width:400px">
      <div class="error-icon" style="margin:0 auto 20px">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <h2 class="page-card-title">Algo deu errado</h2>
      <p style="color:var(--text-muted);font-size:15px;margin:10px 0 28px;line-height:1.6"><%= message %></p>
      <a href="/" class="btn btn-ghost" style="width:100%">Voltar ao início</a>
    </div>
  </div>
</body>
</html>
