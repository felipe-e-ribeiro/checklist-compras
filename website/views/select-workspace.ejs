<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Seus Ambientes — Lista de Compras</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="page-center">
    <div class="page-card">
      <div class="page-card-header">
        <div class="brand" style="margin-bottom:24px">
          <div class="brand-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 01-8 0"/>
            </svg>
          </div>
          Lista de Compras
        </div>
        <h2 class="page-card-title">Seus Ambientes</h2>
        <p class="page-card-sub">Olá, <%= user.email %>. Escolha um ambiente para continuar.</p>
      </div>

      <div class="workspace-list">
        <% tenants.forEach(function(tenant) { %>
          <div class="workspace-card">
            <form method="POST" action="/select-workspace">
              <input type="hidden" name="tenantId" value="<%= tenant.id %>">
              <button type="submit" class="workspace-card-btn">
                <span>
                  <span class="workspace-name"><%= tenant.name %></span>
                </span>
                <span style="display:flex;align-items:center;gap:8px">
                  <% if (tenant.role === 'owner') { %>
                    <span class="workspace-role owner">Dono</span>
                  <% } else { %>
                    <span class="workspace-role">Membro</span>
                  <% } %>
                  <span class="workspace-arrow">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M9 18l6-6-6-6"/>
                    </svg>
                  </span>
                </span>
              </button>
            </form>
          </div>
        <% }); %>
      </div>

      <div class="divider"></div>

      <a href="/create-workspace" class="btn btn-ghost" style="width:100%">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Criar novo ambiente
      </a>
    </div>
  </div>
</body>
</html>
