<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Acesso — Lista de Compras</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="login-page">
    <div class="login-card">
      <div class="login-mark">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0110 0v4"/>
        </svg>
      </div>

      <h1 class="login-title">Acesso<br>Direto</h1>
      <p class="login-sub">Autenticação local para sessões de teste.</p>

      <% if (error) { %>
        <div style="background:var(--danger-light);color:var(--danger);border-radius:var(--radius-sm);padding:10px 14px;font-size:14px;margin-bottom:16px;">
          <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/access" style="display:flex;flex-direction:column;gap:12px">
        <div class="form-field" style="margin-bottom:0">
          <label class="form-label" for="username">Usuário</label>
          <input class="input-field" type="text" id="username" name="username"
                 placeholder="loadtest" autocomplete="username" autofocus required>
        </div>
        <div class="form-field" style="margin-bottom:0">
          <label class="form-label" for="password">Senha</label>
          <input class="input-field" type="password" id="password" name="password"
                 placeholder="••••••••" autocomplete="current-password" required>
        </div>
        <button type="submit" class="btn btn-primary" style="height:50px;font-size:15px;margin-top:4px">
          Entrar
        </button>
      </form>

      <div class="login-divider"></div>
      <p style="font-size:12px;color:var(--text-muted);text-align:center">
        Acesso restrito — somente para testes autorizados.
      </p>
    </div>
  </div>
</body>
</html>
